{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "python3 scripts/session_banner.py",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "python3 scripts/pre_tool_policy.py",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ]
  }
}
